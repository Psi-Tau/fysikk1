<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <title>Snake</title>
  <style>
    body {
      font-family: Arial, sans-serif;
    }
    canvas {
      border: 1px solid black;
      background: #f5f5f5;
    }
  </style>
</head>
<body>

<h1>Snake</h1>
<canvas id="spill" width="400" height="400"></canvas>

<script>
// --- Oppsett ---
const canvas = document.getElementById("spill");
const ctx = canvas.getContext("2d");

const rute = 20;

let slange = [
  { x: 200, y: 200 }
];

let dx = rute;
let dy = 0;

let mat = { x: 100, y: 100 };
let poeng = 0;
let stopp = false;

// --- Funksjoner ---
function tegn() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  // Tegn mat
  ctx.fillStyle = "red";
  ctx.fillRect(mat.x, mat.y, rute, rute);

  // Tegn slange
  ctx.fillStyle = "green";
  for (let del of slange) {
    ctx.fillRect(del.x, del.y, rute, rute);
  }

  ctx.fillStyle = "black";
  ctx.fillText("Poeng: " + poeng, 10, 15);
}

function nyMat() {
  mat.x = Math.floor(Math.random() * 20) * rute;
  mat.y = Math.floor(Math.random() * 20) * rute;
}

function oppdater() {
  if (stopp) return;

  let hode = {
    x: slange[0].x + dx,
    y: slange[0].y + dy
  };

  // vegger
  if (hode.x < 0 || hode.y < 0 || hode.x >= 400 || hode.y >= 400) {
    stopp = true;
    alert("Game over! Poeng: " + poeng);
    return;
  }

  // egen kropp
  for (let del of slange) {
    if (hode.x === del.x && hode.y === del.y) {
      stopp = true;
      alert("Game over! Poeng: " + poeng);
      return;
    }
  }

  slange.unshift(hode);

  if (hode.x === mat.x && hode.y === mat.y) {
    poeng = poeng + 1;
    nyMat();
  } else {
    slange.pop();
  }

  tegn();
}

// --- Tastatur ---
document.addEventListener("keydown", function(event) {
  if (event.key === "ArrowUp" && dy === 0) {
    dx = 0; dy = -rute;
  }
  if (event.key === "ArrowDown" && dy === 0) {
    dx = 0; dy = rute;
  }
  if (event.key === "ArrowLeft" && dx === 0) {
    dx = -rute; dy = 0;
  }
  if (event.key === "ArrowRight" && dx === 0) {
    dx = rute; dy = 0;
  }
});

setInterval(oppdater, 150);
tegn();
</script>

</body>
</html>
